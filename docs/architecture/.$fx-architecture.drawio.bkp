        </mxCell>
        <mxCell id="e6" edge="1" source="kafka" target="index" parent="1" value="fan-out">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" edge="1" source="index" target="os" parent="1" value="index">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" edge="1" source="os" target="ui" parent="1" value="query">
