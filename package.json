{
  "name": "fx-trade-analytics-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "local:docker:up": "bash devops/local/docker-all-up.sh",
    "local:docker:down": "bash devops/local/docker-all-down.sh",
    "local:docker:status": "bash devops/local/docker-all-status.sh",

    "local:app:trade": "mvn spring-boot:run -pl middleware/fx-trade-service",
    "local:app:risk": "mvn spring-boot:run -pl middleware/fx-risk-service",
    "local:app:indexer": "mvn spring-boot:run -pl middleware/fx-opensearch-indexer",
    "local:app:masterdata": "mvn spring-boot:run -pl middleware/fx-masterdata-service",
    "local:app:masterdata:postgres": "mvn spring-boot:run -pl middleware/fx-masterdata-service -Dspring-boot.run.profiles=postgres",

    "local:app:run-all": "concurrently -k \"npm:local:app:trade\" \"npm:local:app:risk\" \"npm:local:app:indexer\" \"npm:local:app:masterdata\"",

    "portals:install": "cd portals && npm install",
    "portals:ensure-install": "cd portals && npm install --prefer-offline --no-audit --no-fund",
    "local:ui:admin": "npm run portals:ensure-install && cd portals && npm run start:admin",
    "local:ui:customer": "npm run portals:ensure-install && cd portals && npm run start:customer",

    "local:ui:run-all": "npm run portals:ensure-install && concurrently -k -n admin,customer \"cd portals && npm run start:admin\" \"cd portals && npm run start:customer\"",

    "local:start": "npm run local:docker:up && concurrently -k \"npm:local:app:run-all\" \"npm:local:ui:run-all\"",
    "local:stop": "bash devops/local/shutdown-all.sh",
    "local:status": "bash devops/local/status-all.sh",

    "fx:start": "npm run local:docker:up && pm2 start ecosystem.config.js",
    "fx:status": "pm2 list && npm run local:docker:status",
    "fx:stop": "pm2 delete all && npm run local:docker:down",

    "setup:aws:iam-all": "bash .github/aws/scripts/aws-iam-setup.sh",
    "destroy:aws:iam-all": "bash .github/aws/scripts/aws-iam-destroy.sh"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}