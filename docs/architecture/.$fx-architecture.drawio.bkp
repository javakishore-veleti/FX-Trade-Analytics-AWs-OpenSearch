        </mxCell>
        <!-- Edges -->
        <mxCell id="e1" edge="1" source="cust" target="trade" parent="1" value="POST /trades">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" edge="1" source="admin" target="trade" parent="1" value="Manage Trades">
