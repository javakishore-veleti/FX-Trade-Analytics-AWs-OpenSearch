{
  "name": "portals",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve admin-portal",
    "start:admin": "ng serve admin-portal --port 4200 --proxy-config projects/admin-portal/proxy.conf.json",
    "start:customer": "ng serve customer-portal --port 4201 --proxy-config projects/customer-portal/proxy.conf.json",
    "build:admin": "ng build admin-portal",
    "build:customer": "ng build customer-portal",
    "build": "ng build admin-portal && ng build customer-portal"
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/cdk": "^21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
